# Copy to .env and fill in. Never commit .env.
# See the deployment notes for what each value is for.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
AUTH_ALLOWED_DOMAIN=
CLAUDE_CODE_OAUTH_TOKEN=

# Customer Proposal Portal integration (the "Send to customer portal" button +
# Customer Portal page proxy to the portal's admin API). Must match the portal's
# SERVICE_TOKEN. PORTAL_ADMIN_URL is the portal's base URL (no trailing slash).
PORTAL_ADMIN_URL=
SERVICE_TOKEN=

# Dropbox — the step-5 "To Dropbox" upload (creates the project folder in the
# Treadwell Team Dropbox + uploads the estimate/proposal/PDF). Prefer the modern
# refresh-token flow (long-lived, auto-refreshing); mint the token once with
# backend/dropbox_oauth_setup.py. DROPBOX_ACCESS_TOKEN is a legacy fallback.
# Destinations (Estimating category folders) are hardcoded in dropbox_client.py.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# DROPBOX_ACCESS_TOKEN=       # legacy alternative to the refresh-token trio
