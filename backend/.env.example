# Copy to .env and fill in. Never commit .env.
#
# Dropbox app token — generated at https://www.dropbox.com/developers/apps
# (Create app → Scoped access → "App folder" type → generate access token.)
# Without this set, the tool falls back to direct file downloads (no upload).
DROPBOX_ACCESS_TOKEN=

# Folder inside the Dropbox app's root where new proposal folders go.
# Leading slash required. Defaults to "/Proposals" if unset.
DROPBOX_ROOT_FOLDER=/Proposals
