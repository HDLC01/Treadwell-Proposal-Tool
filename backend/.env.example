# Copy to .env and fill in. NEVER commit .env.
#
# The app is one FastAPI container that serves the API AND the static
# frontend. /api/* is gated on a Supabase Google-auth token, so the SUPABASE_*
# keys below are required even for local dev sign-in.

# ── Supabase: auth + data ─────────────────────────────────────────────
# Cloud Supabase project URL — Google auth + JWT verification (JWKS).
SUPABASE_URL=
# Server-side service-role key (bypasses RLS) — data access + auth-admin ops.
# SECRET. Never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Publishable anon key handed to the frontend for sign-in.
SUPABASE_ANON_KEY=
# Email domain allowed to sign in (default: wetreadwell.com).
AUTH_ALLOWED_DOMAIN=wetreadwell.com
# Only if the Supabase project signs JWTs with HS256 (legacy shared secret).
SUPABASE_JWT_SECRET=
# Bootstrap super-admin (granted the Admin view on first sign-in).
SUPER_ADMIN_EMAIL=

# Staging only: point the DATA store (drafts/events/profiles) at the VPS
# self-hosted PostgREST instead of cloud Supabase. Leave unset in prod.
# SUPABASE_DATA_URL=http://rest
# SUPABASE_DATA_KEY=

# ── AI Autofill (Claude CLI) ──────────────────────────────────────────
# Long-lived OAuth token from `claude setup-token` (~1 yr). Authenticates the
# in-container `claude -p` CLI that drafts the proposal narrative + estimate
# flags. Re-mint if it ever expires (see CLAUDE.md).
CLAUDE_CODE_OAUTH_TOKEN=
# Legacy fallback only — a raw Anthropic API key. The OAuth CLI above is primary.
# ANTHROPIC_API_KEY=

# ── Legacy / inert ────────────────────────────────────────────────────
# The Dropbox-folder upload path was retired 2026-06-09; the tool now returns
# direct downloads (.xlsx / .docx / PDF) only. These are ignored on the live
# path and kept solely so older code/tests still import cleanly.
# DROPBOX_ACCESS_TOKEN=
# DROPBOX_ROOT_FOLDER=/Proposals
