# Staging env — copy to .env.staging on the VPS (/opt/treadwell-staging) and fill.
# AUTH uses the SAME cloud Supabase project as prod (Google login works on
# staging once staging.proposals is an authorized redirect). DATA goes to the
# local PostgREST (set in docker-compose.staging.yml, not here).

# ── Cloud Supabase (AUTH only — JWKS verify + auth.admin) ──
SUPABASE_URL=https://hyjowrzgrrxrbfbaxkyu.supabase.co
SUPABASE_ANON_KEY=<prod anon key>
SUPABASE_SERVICE_ROLE_KEY=<prod service-role key>
SUPABASE_JWT_SECRET=<optional, prod value>
AUTH_ALLOWED_DOMAIN=wetreadwell.com
SUPER_ADMIN_EMAIL=hanz@wetreadwell.com

# NOTE: SUPABASE_DATA_URL / SUPABASE_DATA_KEY are set in docker-compose.staging.yml
# (→ the local PostgREST). Do NOT point them at cloud Supabase or staging will
# write into prod data.

# ── Dropbox (staging writes to a _staging subfolder; reuse prod creds) ──
DROPBOX_APP_KEY=<prod>
DROPBOX_APP_SECRET=<prod>
DROPBOX_REFRESH_TOKEN=<prod>

# ── Autofill (Claude CLI logged in inside the container) ──
AUTOFILL_MODEL=sonnet
