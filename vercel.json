{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "frontend",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://guidebooky-gideon-pellucid.ngrok-free.dev/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
